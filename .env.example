# Environment variables - Copy this file to .env and fill in your values

# =============================================================================
# Anthropic API
# =============================================================================
ANTHROPIC_API_KEY=null
ANTHROPIC_AUTH_TOKEN=null

# Proxy URL for Anthropic API (optional, leave commented if not using proxy)
ANTHROPIC_BASE_URL=null

# Claude model to use for markdown analysis (default: claude-haiku-4-5)
LLM_MODEL=claude-haiku-4-5

# =============================================================================
# Redmine API
# =============================================================================
REDMINE_URL=https://redmine.com/
REDMINE_API_KEY=null

# Default project identifier (optional, can be selected in UI)
# REDMINE_DEFAULT_PROJECT=my-project

# =============================================================================
# Server Config (optional)
# =============================================================================
HOST=127.0.0.1
PORT=8000
